# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Google Cloud (for production deployment)
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=prismux-screenshots
FIRESTORE_PROJECT=your-gcp-project-id

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Browser
BROWSER_HEADLESS=true
SCREENSHOT_WIDTH=1280
SCREENSHOT_HEIGHT=720
MAX_STEPS=30

# Gemini Models
GEMINI_PERCEPTION_MODEL=gemini-2.0-flash
GEMINI_EVALUATION_MODEL=gemini-2.0-flash
GEMINI_REPORT_MODEL=gemini-2.5-pro-preview-05-06
